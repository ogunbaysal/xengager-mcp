# App
PORT=3000
NODE_ENV=development

# Optional: protect your public MCP endpoint.
# Leave empty for local dev. Set a strong random value for public testing.
MCP_API_KEY=

# Cloudflare Tunnel (replaces ngrok)
# 1. Add your domain to Cloudflare (https://dash.cloudflare.com)
# 2. Create a tunnel at https://one.dash.cloudflare.com/ → Networks → Tunnels
# 3. Copy the tunnel token and paste it below
CLOUDFLARE_TUNNEL_TOKEN=

# Static hostname for your tunnel (e.g., mcp.yourdomain.com).
# Configure this in the Cloudflare Zero Trust dashboard under your tunnel's public hostnames,
# pointing to http://mcp:6660 (the Docker service name).
TUNNEL_HOSTNAME=

# X (Twitter) Authentication
# Get these from your browser's DevTools → Application → Cookies → x.com
X_AUTH_TOKEN=your_auth_token_cookie_value_here
X_CT0=your_ct0_cookie_value_here
